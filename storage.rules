rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow signed-in users to read/write any file under rfq-attachments/
    match /rfq-attachments/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Catch-all: deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
